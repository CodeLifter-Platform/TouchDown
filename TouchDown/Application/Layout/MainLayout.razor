@using TD.Themes
@using TD.Components.Consent
@using TD.Services
@inherits LayoutComponentBase
@inject IUserPreferencesService Prefs

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_currentTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<TelemetryConsentModal OnResolved="@(() => InvokeAsync(StateHasChanged))" />

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Fixed="true" Class="td-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="td-logo">TD</MudText>
        <MudSpacer />
        <MudMenu Icon="@Icons.Material.Filled.Palette" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight" Dense="true">
            @foreach (var entry in ThemeRegistry.All)
            {
                <MudMenuItem OnClick="@(() => SetTheme(entry.Key))"
                             Style="@(entry.Key == _selectedThemeName ? "font-weight:600;" : "")">
                    @entry.Key
                </MudMenuItem>
            }
            <MudDivider />
            <MudMenuItem OnClick="@ToggleDarkMode">
                @(_isDarkMode ? "Light Mode" : "Dark Mode")
            </MudMenuItem>
        </MudMenu>
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="@ToggleDarkMode" />
        <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Inherit" Href="/new-drive" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="1" Variant="DrawerVariant.Mini"
               OpenMiniOnHover="true">
        <MudNavMenu>
            <MudNavLink Href="/" Icon="@Icons.Material.Filled.Dashboard" Match="NavLinkMatch.All">Dashboard</MudNavLink>
            <MudNavLink Href="/new-drive" Icon="@Icons.Material.Filled.PlayArrow">New Drive</MudNavLink>
            <MudNavLink Href="/teams" Icon="@Icons.Material.Filled.Groups">Teams</MudNavLink>
            <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">Settings</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pa-4" Style="padding-top: 64px !important;">
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">X</span>
</div>

@code {
    private bool _drawerOpen;
    private bool _isDarkMode = true;
    private MudTheme _currentTheme = ThemeRegistry.Default;
    private string _selectedThemeName = "TouchDown";

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;

    private void SetTheme(string name)
    {
        if (ThemeRegistry.All.TryGetValue(name, out var theme))
        {
            _currentTheme = theme;
            _selectedThemeName = name;
        }
    }
}
