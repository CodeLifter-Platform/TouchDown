@using TD.Models
@using TD.Areas.Drives.Monitor

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Person" />
            <MudText Typo="Typo.h6">@AgentName — Transcript</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (Plays.Count == 0)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">No plays assigned to this agent.</MudText>
        }
        else
        {
            <MudExpansionPanels MultiExpansion="true" Elevation="0">
                @foreach (var play in Plays.OrderBy(p => p.OrderIndex))
                {
                    <MudExpansionPanel>
                        <TitleContent>
                            <div class="d-flex align-center gap-2" style="width: 100%;">
                                <MudIcon Icon="@GetStatusIcon(play.Status)" Color="@GetStatusColor(play.Status)" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Style="flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    @play.Description
                                </MudText>
                                @if (play.Duration.HasValue)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatDuration(play.Duration.Value)</MudText>
                                }
                            </div>
                        </TitleContent>
                        <ChildContent>
                            @if (!string.IsNullOrWhiteSpace(play.Output))
                            {
                                <pre style="white-space: pre-wrap; word-break: break-word; max-height: 500px; overflow-y: auto; font-size: 0.8rem; background: var(--mud-palette-background-gray); padding: 12px; border-radius: 4px; margin: 0;">@play.Output</pre>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary">No output recorded.</MudText>
                            }
                        </ChildContent>
                    </MudExpansionPanel>
                }
            </MudExpansionPanels>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public string AgentName { get; set; } = "";
    [Parameter] public List<PlaySummaryVM> Plays { get; set; } = [];

    private void Cancel() => MudDialog.Close();

    private static string GetStatusIcon(PlayStatus status) => status switch
    {
        PlayStatus.Completed => Icons.Material.Filled.CheckCircle,
        PlayStatus.Failed    => Icons.Material.Filled.Cancel,
        PlayStatus.Skipped   => Icons.Material.Filled.SkipNext,
        _                    => Icons.Material.Outlined.RadioButtonUnchecked
    };

    private static Color GetStatusColor(PlayStatus status) => status switch
    {
        PlayStatus.Completed  => Color.Success,
        PlayStatus.Failed     => Color.Error,
        PlayStatus.Skipped    => Color.Warning,
        PlayStatus.InProgress => Color.Info,
        _                     => Color.Default
    };

    private static string FormatDuration(TimeSpan d) =>
        d.TotalMinutes >= 1 ? $"{(int)d.TotalMinutes}m {d.Seconds}s" : $"{d.Seconds}s";
}
