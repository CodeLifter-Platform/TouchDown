@page "/drive/{DriveId}"
@using Microsoft.AspNetCore.SignalR.Client
@using System.Text.Json
@using TD.MVVM.Components
@using TD.Areas.Drives.Monitor.Components
@inherits ViewComponentBase<DrivesMonitorPageVM>
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>TD - @(VM.Drive?.DisplayName ?? DriveId)</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large">
    <div class="d-flex justify-space-between align-center mb-4">
        <div class="d-flex align-center gap-3">
            @if (_editingName)
            {
                <MudTextField @bind-Value="_nameDraft" Variant="Variant.Outlined" Margin="Margin.Dense"
                              Immediate="true" MaxLength="100" Style="min-width: 280px;"
                              Placeholder="Name this drive…" OnKeyDown="NameKeyDown" Adornment="Adornment.End"
                              AdornmentIcon="@Icons.Material.Filled.Check" OnAdornmentClick="SaveName" />
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="CancelEditName" />
            }
            else
            {
                <div>
                    <div class="d-flex align-center gap-1">
                        <MudText Typo="Typo.h5">@(VM.Drive?.DisplayName ?? DriveId)</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       Disabled="@(VM.Drive == null)" OnClick="StartEditName" />
                    </div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family: monospace;">@DriveId</MudText>
                </div>
            }
            @if (VM.Drive != null)
            {
                <MudChip T="string" Size="Size.Small" Color="@DrivesMonitorPageVM.GetStatusColor(VM.Drive.Status)" Variant="Variant.Filled">
                    @VM.Drive.Status
                </MudChip>
                @if (!string.IsNullOrWhiteSpace(VM.Drive.ModelId))
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                             Icon="@Icons.Material.Filled.Memory">
                        @VM.Drive.ModelId
                    </MudChip>
                }
                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                         Icon="@Icons.Material.Filled.Bolt">
                    @VM.Drive.Effort.ToDisplayName() effort
                </MudChip>
                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Text"
                         Icon="@(VM.Drive.OverrideTeamConfig ? Icons.Material.Filled.Groups : Icons.Material.Filled.Person)">
                    @(VM.Drive.OverrideTeamConfig ? "whole squad" : "QB only")
                </MudChip>
            }
        </div>
        <div class="d-flex gap-2">
            @if (VM.Drive?.Status == DriveStatus.InProgress)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="() => VM.CancelDriveCommand.ExecuteAsync(null)"
                           StartIcon="@Icons.Material.Filled.Stop" Size="Size.Small">
                    Cancel
                </MudButton>
            }
            <MudButton Variant="Variant.Outlined" Href="/new-drive"
                       StartIcon="@Icons.Material.Filled.Add" Size="Size.Small">
                New Drive
            </MudButton>
        </div>
    </div>

    @if (VM.Drive != null)
    {
        @* ── Phase banner (only while running) ── *@
        @if (VM.Drive.Status == DriveStatus.InProgress)
        {
            <MudPaper Outlined="true" Class="mb-4 pa-3 d-flex align-center gap-3">
                <MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary" />
                <div>
                    <MudText Typo="Typo.body2" Style="font-weight: 600;">@VM.CurrentPhase</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Drive in progress…</MudText>
                </div>
            </MudPaper>
        }

        @* ── Agent status cards ── *@
        <MudGrid Class="mb-4">
            @foreach (var status in VM.AgentStatuses)
            {
                var agentName = status.Key;
                <MudItem xs="12" sm="6" md="4" lg="2">
                    <MudCard Outlined="true" Style="cursor: pointer;" @onclick="() => OpenTranscript(agentName)">
                        <MudCardContent Class="pa-3">
                            <div class="d-flex justify-space-between align-center mb-2">
                                <MudText Typo="Typo.body2" Style="font-weight: 600;">@status.Key</MudText>
                                <MudChip T="string" Size="Size.Small" Color="@DrivesMonitorPageVM.GetAgentStatusColor(status.Value.Status)"
                                         Variant="Variant.Outlined">
                                    @status.Value.Status
                                </MudChip>
                            </div>
                            <MudProgressLinear Value="@status.Value.Progress" Color="Color.Primary" Rounded="true" Size="Size.Small" />
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>

        @* ── Play board (visible once plays are assigned) ── *@
        @if (VM.Plays.Count > 0)
        {
            <PlayBoard Plays="VM.Plays" />
        }

        @if (VM.Drive.Status is DriveStatus.Touchdown or DriveStatus.Turnover)
        {
            <PostDriveActions Drive="VM.Drive" />
        }

        @* ── Conversation (huddle chat, QB plan, agent turns) ── *@
        <ConversationPanel Turns="VM.Turns" />

        <MudPaper Outlined="true" Class="mt-4">
            <MudToolBar Dense="true">
                <MudIcon Icon="@Icons.Material.Filled.Terminal" Class="mr-2" Size="Size.Small" />
                <MudText Typo="Typo.subtitle2">Play-by-Play</MudText>
                <MudSpacer />
                <MudText Typo="Typo.caption" Color="Color.Secondary">@VM.Logs.Count entries</MudText>
            </MudToolBar>
            <MudDivider />
            <div class="log-stream pa-2">
                @foreach (var log in VM.Logs)
                {
                    <div class="log-entry @log.Level.ToLower()">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="min-width: 70px; display: inline;">
                            @log.Timestamp.ToString("HH:mm:ss")
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Primary" Style="min-width: 130px; display: inline; font-weight: 600;">
                            [@log.AgentName]
                        </MudText>
                        <MudText Typo="Typo.caption" Style="display: inline;">
                            @log.Message
                        </MudText>
                    </div>
                }
            </div>
        </MudPaper>
    }
    else
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        <MudText Class="ml-3" Typo="Typo.body2" Color="Color.Secondary">Loading drive data...</MudText>
    }
</MudContainer>

@code {
    [Parameter] public string DriveId { get; set; } = null!;
    [Inject] private NavigationManager Navigation { get; set; } = null!;
    [Inject] private IDialogService DialogService { get; set; } = null!;

    private HubConnection? hubConnection;
    private bool _editingName;
    private string _nameDraft = "";

    private void StartEditName()
    {
        _nameDraft = VM.Drive?.Name ?? "";
        _editingName = true;
    }

    private void CancelEditName() => _editingName = false;

    private async Task SaveName()
    {
        await VM.RenameDriveCommand.ExecuteAsync(_nameDraft);
        _editingName = false;
    }

    private async Task NameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SaveName();
        else if (e.Key == "Escape") CancelEditName();
    }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await VM.LoadDriveAsync(DriveId);

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/agentHub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<JsonElement>("ReceiveLog", (log) =>
        {
            VM.AddLog(new LogEntry
            {
                Timestamp = DateTime.UtcNow,
                AgentName = log.TryGetProperty("AgentName", out var an) ? an.GetString() ?? "System" : "System",
                Message = log.TryGetProperty("Message", out var msg) ? msg.GetString() ?? "" : "",
                Level = log.TryGetProperty("Level", out var lvl) ? lvl.GetString() ?? "Info" : "Info"
            });
            InvokeAsync(StateHasChanged);
        });

        hubConnection.On<JsonElement>("AgentStatusUpdate", (update) =>
        {
            var agentName = update.TryGetProperty("AgentName", out var an) ? an.GetString() ?? "" : "";
            var status = update.TryGetProperty("Status", out var s) ? s.GetString() ?? "" : "";
            var progress = update.TryGetProperty("ProgressPercent", out var p) ? p.GetInt32() : 0;
            VM.UpdateAgentStatus(agentName, status, progress);
            InvokeAsync(StateHasChanged);
        });

        hubConnection.On<JsonElement>("DriveCompleted", (result) =>
        {
            var status = result.TryGetProperty("Status", out var s) ? s.GetString() ?? "" : "";
            VM.MarkDriveCompleted(status);
            InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
        await hubConnection.InvokeAsync("JoinDrive", DriveId);
    }

    private async Task OpenTranscript(string agentName)
    {
        var agentPlays = VM.Plays.Where(p => p.AgentName == agentName).ToList();
        var parameters = new DialogParameters<AgentTranscriptDialog>
        {
            { x => x.AgentName, agentName },
            { x => x.Plays, agentPlays }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true };
        await DialogService.ShowAsync<AgentTranscriptDialog>(agentName, parameters, options);
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection != null) await hubConnection.DisposeAsync();
        await VM.DisposeAsync();
    }
}
