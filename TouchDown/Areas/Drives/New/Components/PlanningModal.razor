@using TD.Areas.Drives.New

<MudOverlay Visible="true" DarkBackground="true" OnClick="OnClose" ZIndex="1000" />

<MudPaper Class="huddle-modal" Elevation="8">
    <MudToolBar Dense="true" Class="huddle-header">
        <MudIcon Icon="@Icons.Material.Filled.Sports" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.h6">The Huddle</MudText>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="ml-3">
            Planning the playbook with @(Session.Team?.GetLeader()?.Name ?? "Quarterback")
        </MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="OnClose" />
    </MudToolBar>

    <div class="huddle-chat">
        @foreach (var msg in vm.Messages)
        {
            var isUser = msg.Role == "user";
            <div class="d-flex @(isUser ? "justify-end" : "justify-start") mb-2">
                <MudPaper Class="pa-3" MaxWidth="85%" Style="@BubbleStyle(msg.Role)">
                    <div class="d-flex justify-space-between gap-4 mb-1">
                        <MudText Typo="Typo.caption" Style="font-weight: 600;">
                            @(msg.Name ?? (isUser ? "Coach" : "QB"))
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@msg.Timestamp.ToString("HH:mm")</MudText>
                    </div>
                    <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@msg.Content</MudText>
                </MudPaper>
            </div>
        }

        @if (vm.IsStreaming)
        {
            var agentStreaming = vm.StreamingRole != (Session.Team?.GetLeader()?.Name ?? "QB");
            <div class="d-flex justify-start mb-2">
                <MudPaper Class="pa-3" MaxWidth="85%" Style="@BubbleStyle(agentStreaming ? "agent" : "quarterback")">
                    <MudText Typo="Typo.caption" Style="font-weight: 600;" Class="mb-1">
                        @vm.StreamingRole
                    </MudText>
                    <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@vm.StreamingContent<span class="cursor">|</span></MudText>
                </MudPaper>
            </div>
        }
    </div>

    <MudDivider />

    <div class="pa-3">
        <MudTextField @bind-Value="vm.UserInput" Label="" Variant="Variant.Outlined" Lines="2"
                      Placeholder="@(vm.HasResearcher ? "Chat with the QB, or type a question and hit Research…" : "Chat with the QB to refine the playbook...")"
                      Disabled="@vm.IsStreaming" Immediate="true" OnKeyDown="HandleKeyDown" Class="mb-2" />
        <div class="d-flex justify-end gap-2">
            <MudButton Variant="Variant.Outlined" OnClick="() => vm.RollCallCommand.ExecuteAsync(null)"
                       Disabled="@vm.IsStreaming"
                       StartIcon="@Icons.Material.Filled.Groups">
                Roll Call
            </MudButton>
            @if (vm.HasResearcher)
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Tertiary"
                           OnClick="() => vm.EnlistResearcherCommand.ExecuteAsync(null)"
                           Disabled="@(vm.IsStreaming || string.IsNullOrWhiteSpace(vm.UserInput))"
                           StartIcon="@Icons.Material.Filled.TravelExplore">
                    Research
                </MudButton>
            }
            <MudButton Variant="Variant.Outlined" OnClick="() => vm.SendMessageCommand.ExecuteAsync(null)"
                       Disabled="@(vm.IsStreaming || string.IsNullOrWhiteSpace(vm.UserInput))"
                       StartIcon="@Icons.Material.Filled.Send">
                Send
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SnapTheBall"
                       Disabled="@(!vm.CanSnap)"
                       StartIcon="@Icons.Material.Filled.SportsCricket">
                Snap the Ball!
            </MudButton>
        </div>
    </div>
</MudPaper>

@code {
    [Parameter] public AgentSession Session { get; set; } = null!;
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<string> OnLaunch { get; set; }

    [Inject] private HuddleVM vm { get; set; } = null!;
    [Inject] private IDialogService DialogService { get; set; } = null!;
    [Inject] private IGitWorktreeService GitService { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        vm.PropertyChanged += (_, _) => InvokeAsync(StateHasChanged);
        await vm.InitializeWithSession(Session);
    }

    private async Task SnapTheBall()
    {
        if (!await EnsureGitInitialized()) return;
        var driveId = await vm.SnapTheBall();
        if (driveId != null) await OnLaunch.InvokeAsync(driveId);
    }

    private async Task<bool> EnsureGitInitialized()
    {
        if (Session.WorkspaceMode != WorkspaceMode.FreshFolder)
            return true;

        var path = Session.RepoPath;
        if (string.IsNullOrWhiteSpace(path) || !Directory.Exists(path))
            return true;

        if (Directory.Exists(Path.Combine(path, ".git")))
            return true;

        var result = await DialogService.ShowMessageBoxAsync(
            "Initialize Git?",
            "This folder doesn't have a git repository. Would you like to initialize one so the drive can track changes?",
            yesText: "Init & Continue", cancelText: "Cancel");

        if (result != true) return false;

        await GitService.InitRepoAsync(path);
        return true;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e is { Key: "Enter", ShiftKey: false })
            await vm.SendMessageCommand.ExecuteAsync(null);
    }

    private static string BubbleStyle(string role) => role switch
    {
        "user" => "background: rgba(59,130,246,0.12);",
        "quarterback" => "background: rgba(249,115,22,0.08); border: 1px solid rgba(249,115,22,0.2);",
        // coordinator, rollcall, and any other agent voice
        _ => "background: rgba(20,184,166,0.10); border: 1px solid rgba(20,184,166,0.30);"
    };
}
