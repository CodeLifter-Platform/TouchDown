@using TD.Areas.Shared
@using TD.Areas.Drives.New

<MudText Typo="Typo.h6" Class="mb-1">Source Selection</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Choose your agent provider, where your code lives, which branch to start from, and how agents should work on it.
</MudText>

@* ───── Agent Provider ───── *@
<MudText Typo="Typo.subtitle2" Class="mb-2">Agent Provider</MudText>
@if (loadingProviders)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (availableProviders.Count == 0)
{
    <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Outlined" Class="mb-4"
              Icon="@Icons.Material.Filled.ErrorOutline">
        No agent providers available. Install and authenticate Claude Code or Codex CLI.
    </MudAlert>
}
else
{
    <MudToggleGroup T="string" Value="Session.ProviderId" ValueChanged="SetProvider"
                    Color="Color.Primary" CheckMark="true" Class="mb-4">
        @foreach (var provider in availableProviders)
        {
            <MudToggleItem T="string" Value="@provider.ProviderId" Text="@provider.DisplayName" />
        }
    </MudToggleGroup>
}

@* ───── Primary Model & Effort ───── *@
@if (CurrentProviderModels.Count > 0)
{
    <div class="d-flex gap-3 mb-4 flex-wrap">
        <MudSelect T="string" Value="Session.ModelId" ValueChanged="SetModel" Label="Primary Model"
                   Variant="Variant.Outlined" Dense="true" Style="min-width: 280px;"
                   Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Memory"
                   HelperText="The Quarterback's model for this drive">
            @foreach (var m in CurrentProviderModels)
            {
                <MudSelectItem T="string" Value="@m.ModelId">
                    <div class="d-flex flex-column">
                        <MudText Typo="Typo.body2">@m.DisplayName</MudText>
                        @if (!string.IsNullOrEmpty(m.Description))
                        {
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@m.Description</MudText>
                        }
                    </div>
                </MudSelectItem>
            }
        </MudSelect>

        <MudSelect T="AgentEffort" Value="Session.Effort" ValueChanged="SetEffort" Label="Effort"
                   Variant="Variant.Outlined" Dense="true" Style="min-width: 170px;"
                   Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Bolt"
                   HelperText="Reasoning depth">
            @foreach (var e in Enum.GetValues<AgentEffort>())
            {
                <MudSelectItem T="AgentEffort" Value="@e">@e.ToDisplayName()</MudSelectItem>
            }
        </MudSelect>
    </div>

    <MudCheckBox T="bool" Value="Session.OverrideTeamConfig" ValueChanged="SetOverride"
                 Color="Color.Primary" Dense="true" Class="mt-n2">
        Apply this model &amp; effort to the whole squad
    </MudCheckBox>
    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-4" Style="margin-left: 30px;">
        @(Session.OverrideTeamConfig
            ? "Every agent runs on the Quarterback's model and effort."
            : "Each squad agent keeps its own model and effort from the Teams page; the Quarterback still uses the choices above.")
    </MudText>
}

<MudDivider Class="mb-4" />

<MudToggleGroup T="SourceType" Value="Session.SourceType" ValueChanged="SetSourceType"
                Color="Color.Primary" CheckMark="true" Class="mb-4">
    <MudToggleItem T="SourceType" Value="SourceType.GitRepo" Text="Git Repository" />
    <MudToggleItem T="SourceType" Value="SourceType.LocalFolder" Text="Local Folder" />
</MudToggleGroup>

@* ───── Git Repository mode ───── *@
@if (Session.SourceType == SourceType.GitRepo)
{
    <div class="d-flex gap-2 align-end mb-3">
        <MudTextField @bind-Value="Session.RepoPath" Label="Repository Path" Variant="Variant.Outlined"
                      Placeholder="/path/to/your/repo" Immediate="true" Class="flex-grow-1"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Source"
                      TextChanged="OnRepoPathChanged" />
        <MudButton Variant="Variant.Outlined" OnClick="() => OpenPicker(true)"
                   StartIcon="@Icons.Material.Filled.FolderOpen" Size="Size.Medium"
                   Style="height: 56px;">
            Browse
        </MudButton>
    </div>

    @if (isDetectingGit)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
    }

    @if (!string.IsNullOrEmpty(Session.RepoPath) && isGitRepo)
    {
        @* ── Branch picker ── *@
        <MudSelect T="string" @bind-Value="Session.Branch" Label="Starting Branch" Variant="Variant.Outlined"
                   AdornmentIcon="@Icons.Material.Filled.AccountTree" Adornment="Adornment.Start"
                   Class="mb-4" Disabled="@isDetectingGit">
            @foreach (var branch in branches)
            {
                <MudSelectItem T="string" Value="@branch">
                    <div class="d-flex align-center gap-2">
                        @if (branch == currentBranch)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Color="Color.Primary" />
                        }
                        @branch
                        @if (branch == currentBranch)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">current</MudChip>
                        }
                    </div>
                </MudSelectItem>
            }
        </MudSelect>

        @* ── Work mode: commit locally vs. worktree for PR ── *@
        <MudText Typo="Typo.subtitle2" Class="mb-2">How should agents work?</MudText>

        <MudGrid Class="mb-3">
            <MudItem xs="12" sm="6">
                <MudCard Outlined="true" Style="cursor: pointer; height: 100%;"
                         Class="@(Session.WorkspaceMode == WorkspaceMode.CurrentBranch ? "mud-border-primary" : "")"
                         @onclick="() => SetWorkspaceMode(WorkspaceMode.CurrentBranch)">
                    <MudCardContent>
                        <div class="d-flex align-center gap-2 mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.EditNote" Size="Size.Small"
                                     Color="@(Session.WorkspaceMode == WorkspaceMode.CurrentBranch ? Color.Primary : Color.Default)" />
                            <MudText Typo="Typo.subtitle2">Work on Branch Directly</MudText>
                        </div>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Agents commit straight to <strong>@(Session.Branch ?? "this branch")</strong>. Fast, no extra branches.
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudCard Outlined="true" Style="cursor: pointer; height: 100%;"
                         Class="@(Session.WorkspaceMode == WorkspaceMode.PrWorktree ? "mud-border-primary" : "")"
                         @onclick="() => SetWorkspaceMode(WorkspaceMode.PrWorktree)">
                    <MudCardContent>
                        <div class="d-flex align-center gap-2 mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.CallSplit" Size="Size.Small"
                                     Color="@(Session.WorkspaceMode == WorkspaceMode.PrWorktree ? Color.Primary : Color.Default)" />
                            <MudText Typo="Typo.subtitle2">Worktree for PR</MudText>
                        </div>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            Spawn a worktree off <strong>@(Session.Branch ?? "this branch")</strong>, push to origin for a pull request. Your branch stays clean.
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>

        @if (Session.WorkspaceMode == WorkspaceMode.PrWorktree)
        {
            <MudTextField @bind-Value="Session.PrBranchName" Label="PR Branch Name" Variant="Variant.Outlined"
                          Placeholder="@defaultPrBranch" Immediate="true"
                          HelperText="Branch name for the worktree (will be pushed to origin)"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CallSplit" Class="mb-3" />
        }

        <MudAlert Severity="Severity.Success" Dense="true" Variant="Variant.Outlined"
                  Icon="@Icons.Material.Filled.CheckCircle">
            Git repository — @branches.Count branch(es) — @(Session.WorkspaceMode == WorkspaceMode.PrWorktree ? "worktree for PR" : "working on branch directly")
        </MudAlert>
    }
    else if (!string.IsNullOrEmpty(Session.RepoPath) && !isDetectingGit)
    {
        <MudAlert Severity="Severity.Warning" Dense="true" Variant="Variant.Outlined"
                  Icon="@Icons.Material.Filled.Warning">
            Not a git repository. Branch selection is not available.
        </MudAlert>
    }
}
@* ───── Local Folder mode ───── *@
else
{
    <div class="d-flex gap-2 align-end mb-3">
        <MudTextField @bind-Value="Session.RepoPath" Label="Folder Path" Variant="Variant.Outlined"
                      Placeholder="/path/to/folder" Immediate="true" Class="flex-grow-1"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.FolderOpen" />
        <MudButton Variant="Variant.Outlined" OnClick="() => OpenPicker(false)"
                   StartIcon="@Icons.Material.Filled.FolderOpen" Size="Size.Medium"
                   Style="height: 56px;">
            Browse
        </MudButton>
    </div>

    @if (!string.IsNullOrEmpty(Session.RepoPath))
    {
        @if (Directory.Exists(Session.RepoPath))
        {
            <MudAlert Severity="Severity.Success" Dense="true" Variant="Variant.Outlined"
                      Icon="@Icons.Material.Filled.CheckCircle">
                Folder exists
            </MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Error" Dense="true" Variant="Variant.Outlined"
                      Icon="@Icons.Material.Filled.ErrorOutline">
                Folder not found
            </MudAlert>
        }
    }
}

@code {
    [Parameter] public AgentSession Session { get; set; } = null!;
    [Parameter] public EventCallback OnChanged { get; set; }

    [Inject] private IGitWorktreeService GitService { get; set; } = null!;
    [Inject] private IDialogService DialogService { get; set; } = null!;
    [Inject] private IDrivesNewService DriveService { get; set; } = null!;

    private List<AvailableProvider> availableProviders = [];
    private bool loadingProviders = true;
    private List<string> branches = [];
    private string? currentBranch;
    private bool isDetectingGit;
    private bool isGitRepo;
    private string defaultPrBranch => $"touchdown/{Session.Branch ?? "main"}-drive";

    private CancellationTokenSource? _detectCts;

    protected override async Task OnInitializedAsync()
    {
        loadingProviders = true;
        try
        {
            availableProviders = await DriveService.GetAvailableProvidersAsync();
            if (string.IsNullOrEmpty(Session.ProviderId) && availableProviders.Count > 0)
            {
                Session.ProviderId = availableProviders[0].ProviderId;
            }
            EnsureModelSelected();
            await OnChanged.InvokeAsync();
        }
        finally
        {
            loadingProviders = false;
        }
    }

    private IReadOnlyList<AgentModel> CurrentProviderModels =>
        availableProviders.FirstOrDefault(p => p.ProviderId == Session.ProviderId)?.Models ?? [];

    private void EnsureModelSelected()
    {
        var models = CurrentProviderModels;
        if (models.Count == 0) { Session.ModelId = null; return; }
        if (string.IsNullOrEmpty(Session.ModelId) || models.All(m => m.ModelId != Session.ModelId))
            Session.ModelId = models[0].ModelId;
    }

    private async Task SetProvider(string providerId)
    {
        Session.ProviderId = providerId;
        EnsureModelSelected();
        await OnChanged.InvokeAsync();
    }

    private async Task SetModel(string? modelId)
    {
        Session.ModelId = modelId;
        await OnChanged.InvokeAsync();
    }

    private async Task SetEffort(AgentEffort effort)
    {
        Session.Effort = effort;
        await OnChanged.InvokeAsync();
    }

    private async Task SetOverride(bool value)
    {
        Session.OverrideTeamConfig = value;
        await OnChanged.InvokeAsync();
    }

    private async Task SetSourceType(SourceType type)
    {
        Session.SourceType = type;
        Session.Branch = null;
        Session.WorkspaceMode = type == SourceType.LocalFolder ? WorkspaceMode.FreshFolder : WorkspaceMode.CurrentBranch;
        branches = [];
        isGitRepo = false;
        await OnChanged.InvokeAsync();
    }

    private async Task SetWorkspaceMode(WorkspaceMode mode)
    {
        Session.WorkspaceMode = mode;
        if (mode == WorkspaceMode.PrWorktree && string.IsNullOrEmpty(Session.PrBranchName))
            Session.PrBranchName = defaultPrBranch;
        await OnChanged.InvokeAsync();
    }

    private async Task OpenPicker(bool gitMode)
    {
        var parameters = new DialogParameters<FolderPickerDialog>
        {
            { x => x.IsGitMode, gitMode },
            { x => x.AllowCreateFolder, !gitMode },
            { x => x.AllowCreateRepo, gitMode },
            { x => x.InitialPath, Session.RepoPath }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true,
        };

        var dialog = await DialogService.ShowAsync<FolderPickerDialog>(
            gitMode ? "Select Repository" : "Select Folder", parameters, options);

        var result = await dialog.Result;
        if (result is { Canceled: false, Data: string path })
        {
            Session.RepoPath = path;
            await OnRepoPathChanged(path);
            await OnChanged.InvokeAsync();
        }
    }

    private async Task OnRepoPathChanged(string? path)
    {
        _detectCts?.Cancel();
        _detectCts = new CancellationTokenSource();
        var ct = _detectCts.Token;

        branches = [];
        currentBranch = null;
        isGitRepo = false;
        Session.Branch = null;

        if (string.IsNullOrWhiteSpace(path) || !Directory.Exists(path))
            return;

        if (Session.SourceType != SourceType.GitRepo)
            return;

        try { await Task.Delay(300, ct); }
        catch (OperationCanceledException) { return; }

        isDetectingGit = true;
        StateHasChanged();

        try
        {
            var branchList = await GitService.ListBranchesAsync(path, ct);
            if (ct.IsCancellationRequested) return;

            if (branchList.Count > 0)
            {
                isGitRepo = true;
                branches = branchList;

                try { currentBranch = await GitService.GetCurrentBranchAsync(path, ct); }
                catch { currentBranch = null; }

                Session.Branch = currentBranch ?? branches.First();
                Session.WorkspaceMode = WorkspaceMode.CurrentBranch;
                await OnChanged.InvokeAsync();
            }
        }
        catch { isGitRepo = false; }
        finally
        {
            isDetectingGit = false;
            StateHasChanged();
        }
    }
}
