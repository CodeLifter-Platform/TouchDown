@page "/teams"
@using TD.MVVM.Components
@inherits ViewComponentBase<TeamsIndexPageVM>
@rendermode InteractiveServer

<PageTitle>TD - Teams</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudText Typo="Typo.h5" Class="mb-1">Agent Teams</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Manage your agent rosters. Each team has a leader, workers, and specialized roles.
    </MudText>

    <MudStack Spacing="4">
        @foreach (var team in VM.Teams)
        {
            <MudExpansionPanels Elevation="0" Dense="true">
                <MudExpansionPanel Style="background: var(--mud-palette-surface);">
                    <TitleContent>
                        <div class="d-flex align-center gap-2">
                            <MudText Typo="Typo.subtitle1">@team.Name</MudText>
                            @if (team.IsDefault)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">Default</MudChip>
                            }
                        </div>
                    </TitleContent>
                    <ChildContent>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">@team.Description</MudText>

                        <MudSimpleTable Dense="true" Hover="true" Class="mb-3">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Role</th>
                                    <th>Model</th>
                                    <th>System Prompt</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var member in team.Members.OrderBy(m => m.Role))
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-center gap-1">
                                                @if (member.IsLeader)
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.Star" Color="Color.Primary" Size="Size.Small" />
                                                }
                                                @member.Name
                                            </div>
                                        </td>
                                        <td>
                                            <MudChip T="string" Size="Size.Small" Color="@TeamsIndexPageVM.GetRoleColor(member.Role)" Variant="Variant.Outlined">
                                                @member.Role
                                            </MudChip>
                                        </td>
                                        <td><MudText Typo="Typo.body2">@member.Model.ToDisplayName()</MudText></td>
                                        <td style="min-width: 340px;">
                                            @if (VM.EditingMemberId == member.Id)
                                            {
                                                <MudTextField @bind-Value="VM.EditBuffer" Variant="Variant.Outlined"
                                                              Lines="6" MaxLength="4000"
                                                              Immediate="true" Class="mb-2" />
                                                <div class="d-flex justify-end gap-2">
                                                    <MudButton Size="Size.Small" Variant="Variant.Text"
                                                               OnClick="VM.CancelEdit" Disabled="@VM.IsSaving">
                                                        Cancel
                                                    </MudButton>
                                                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                                               StartIcon="@Icons.Material.Filled.Save" Disabled="@VM.IsSaving"
                                                               OnClick="() => VM.SaveEditCommand.ExecuteAsync(member)">
                                                        @(VM.IsSaving ? "Saving…" : "Save")
                                                    </MudButton>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="d-flex align-start gap-1">
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary"
                                                             Style="font-style: italic; white-space: pre-wrap;">@member.SystemPrompt</MudText>
                                                    <MudTooltip Text="Edit prompt">
                                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                                       OnClick="() => VM.BeginEdit(member)" />
                                                    </MudTooltip>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>

                        @if (team.CommunicationRules.Any())
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
                                @foreach (var rule in team.CommunicationRules)
                                {
                                    <MudText Typo="Typo.body2"><strong>@rule.Style</strong> — @rule.Description</MudText>
                                }
                            </MudAlert>
                        }
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
        }
    </MudStack>
</MudContainer>
